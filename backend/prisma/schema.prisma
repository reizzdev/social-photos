generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model followers {
  follower_id                         String    @db.Uuid
  following_id                        String    @db.Uuid
  created_at                          DateTime? @default(now()) @db.Timestamp(6)
  users_followers_follower_idTousers  users     @relation("followers_follower_idTousers", fields: [follower_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_follower")
  users_followers_following_idTousers users     @relation("followers_following_idTousers", fields: [following_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_following")

  @@id([follower_id, following_id])
  @@index([following_id], map: "idx_followers_following")
}

model likes {
  user_id    String    @db.Uuid
  photo_id   String    @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamp(6)
  photos     photos    @relation(fields: [photo_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_like_photo")
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_like_user")

  @@id([user_id, photo_id])
  @@index([photo_id], map: "idx_likes_photo")
}

model photos {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String       @db.Uuid
  image_url     String
  is_private    Boolean?     @default(false)
  like_count    Int?         @default(0)
  created_at    DateTime?    @default(now()) @db.Timestamp(6)
  censored      Boolean?     @default(false)
  collection_id String?      @db.Uuid
  access_type   String?      @default("public") @db.VarChar(20)
  comments      comments[]
  likes         likes[]
  photo_tags    photo_tags[]
  users         users        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")
  collections   collections? @relation(fields: [collection_id], references: [id], onUpdate: NoAction)

  @@index([user_id], map: "idx_photos_user")
}

model users {
  id                                      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username                                String        @unique @db.VarChar(30)
  email                                   String        @unique @db.VarChar(100)
  password                                String
  role                                    String?       @default("USER") @db.VarChar(20)
  bio                                     String?
  created_at                              DateTime?     @default(now()) @db.Timestamp(6)
  avatar_url                              String?
  collections                             collections[]
  comments                                comments[]
  followers_followers_follower_idTousers  followers[]   @relation("followers_follower_idTousers")
  followers_followers_following_idTousers followers[]   @relation("followers_following_idTousers")
  likes                                   likes[]
  photos                                  photos[]
}

model tags {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String       @unique @db.VarChar(50)
  photo_tags photo_tags[]
}

model photo_tags {
  photo_id String @db.Uuid
  tag_id   String @db.Uuid
  photos   photos @relation(fields: [photo_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_photo")
  tags     tags   @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tag")

  @@id([photo_id, tag_id])
}

model comments {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  photo_id   String    @db.Uuid
  user_id    String    @db.Uuid
  content    String
  created_at DateTime? @default(now()) @db.Timestamp(6)
  photos     photos    @relation(fields: [photo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model collections {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @db.Uuid
  title          String    @db.VarChar(100)
  description    String?
  goal_amount    Int?      @default(0)
  current_amount Int?      @default(0)
  deadline_hours Int?      @default(24)
  deadline_at    DateTime? @db.Timestamp(6)
  completed      Boolean?  @default(false)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  is_private     Boolean?  @default(false)
  users          users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  photos         photos[]
}
